      "tags": ["n5", "particle", "subject"],
      "weight": 1.3,
      "layer_membership": ["particles"],
      "metadata": {}
    },
    {
      "id": "n-wo",
      "title": "を (wo)",
      "node_type": "particle",
      "content_data": "Object marker — marks the direct object of a verb.",
