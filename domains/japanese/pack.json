    {
      "id": "n-wa",
      "title": "は (wa)",
      "node_type": "particle",
      "content_data": "Topic marker — marks the sentence topic. Does not mark the grammatical subject.",
      "tags": ["n5", "particle", "topic"],
      "weight": 1.5,
      "layer_membership": ["particles"],
      "metadata": {}
    },
    {
      "id": "n-ga",
      "title": "が (ga)",
      "node_type": "particle",
