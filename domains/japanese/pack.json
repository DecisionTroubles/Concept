      "weight": 1.2,
      "layer_membership": ["particles"],
      "metadata": {}
    },
    {
      "id": "n-ni",
      "title": "に (ni)",
      "node_type": "particle",
      "content_data": "Direction/location/time marker — 'to', 'at', 'on', or 'for'.",
      "tags": ["n5", "particle", "direction"],
      "weight": 1.2,
      "layer_membership": ["particles"],
      "metadata": {}
    },
    {
      "id": "n-de",
      "title": "で (de)",
      "node_type": "particle",
      "content_data": "Location of action / means — 'at' (where action happens) or 'by means of'.",
      "tags": ["n5", "particle", "location"],
      "weight": 1.1,
      "layer_membership": ["particles"],
      "metadata": {}
    },
    {
      "id": "n-masu",
      "title": "ます-form",
      "node_type": "grammar",
      "content_data": "Polite present/future verb form. Used in formal speech and writing. e.g. 食べます (tabemasu).",
      "tags": ["n5", "grammar", "verb", "polite"],
      "weight": 1.4,
      "layer_membership": ["grammar"],
      "metadata": {}
    },
    {
      "id": "n-te",
      "title": "て-form",
      "node_type": "grammar",
      "content_data": "Connects actions, forms requests (〜てください), permission (〜てもいい), and compound verbs. e.g. 食べて (tabete).",
      "tags": ["n5", "grammar", "verb", "conjunctive"],
      "weight": 1.3,
      "layer_membership": ["grammar"],
      "metadata": {}
    },
    {
      "id": "n-nai",
      "title": "ない-form",
      "node_type": "grammar",
      "content_data": "Plain negative form. Negates verbs in casual speech. e.g. 食べない (tabenai).",
      "tags": ["n5", "grammar", "verb", "negative"],
      "weight": 1.1,
      "layer_membership": ["grammar"],
      "metadata": {}
    },
    {
      "id": "n-desu",
      "title": "です (desu)",
      "node_type": "grammar",
      "content_data": "Polite copula — links subject to noun or adjective predicate. Equivalent of 'is/am/are'.",
      "tags": ["n5", "grammar", "copula", "polite"],
      "weight": 1.3,
      "layer_membership": ["grammar"],
      "metadata": {}
    },
    {
      "id": "n-da",
      "title": "だ (da)",
      "node_type": "grammar",
      "content_data": "Plain copula — casual equivalent of です. Used in plain-form sentences.",
      "tags": ["n5", "grammar", "copula", "plain"],
      "weight": 1.1,
      "layer_membership": ["grammar"],
      "metadata": {}
