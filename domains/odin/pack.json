        {
          "id": "pointer-indirect-access",
          "title": "Indirect access warning",
          "node_type": "concept",
          "note_type_id": "odin-concept",
          "note_fields": {
            "Summary": "Pointer use means the code is now reasoning through indirection instead of directly through values.",
            "Why": "That shifts how structs and mutation should be read.",
            "Example": "A pointer to User means the procedure is working with a referenced shape, not a copied one.",
            "Pitfall": "Learning pointer syntax before understanding what changed semantically.",
            "Signals": "Parent = pointer."
          },
          "content_data": "Sublayer note for pointer.",
