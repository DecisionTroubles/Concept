  "nodes": [
    {
      "id": "odin-root",
      "title": "Odin Overview",
      "node_type": "root",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Odin is a systems language world centered on explicit declarations, structured data, and pragmatic runtime patterns.",
        "Why": "This root node anchors the first-pass learning route through the world.",
        "Example": "Use this as the entry point before branching into declarations, data layout, and runtime ideas.",
        "Pitfall": "Do not treat every edge as equal. The connection layers intentionally mean different things.",
        "Signals": "Gradual = learning order. Conceptual = mental model. Usage = common co-usage."
      },
      "content_data": "Root overview for the Odin language dataset.",
      "tags": [
        "group:syntax"
      ],
      "weight": 1.55,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "package",
      "title": "package",
      "node_type": "grammar",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Declares the package scope for a file.",
        "Why": "Package layout is one of the first structural ideas to understand.",
        "Example": "package core",
        "Pitfall": "Mixing package intent and import intent makes the module boundary harder to reason about.",
        "Signals": "Usually appears with import and top-level declarations."
      },
      "content_data": "Package declaration in Odin.",
      "tags": [
        "group:syntax"
      ],
      "weight": 1.25,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "import",
      "title": "import",
      "node_type": "grammar",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Brings external packages or modules into scope.",
        "Why": "Imports are where package boundaries become useful rather than abstract.",
        "Example": "import fmt",
        "Pitfall": "A learner can read import syntax without yet understanding why package boundaries matter.",
        "Signals": "Connects strongly to package and procedure-level usage."
      },
      "content_data": "Import statement and package access.",
      "tags": [
        "group:syntax",
        "group:runtime"
      ],
      "weight": 1.18,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "declaration",
      "title": "declaration",
      "node_type": "concept",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Top-level declarations introduce named entities such as variables, constants, procedures, and types.",
        "Why": "It is the bridge from syntax into the rest of the language surface.",
        "Example": "A file typically contains a package line, imports, then declarations.",
        "Pitfall": "Thinking in isolated syntax forms instead of one declaration space makes the map harder to navigate.",
        "Signals": "This is a bridge node between the syntax and declarations groups."
      },
      "content_data": "Top-level declaration model.",
      "tags": [
        "group:syntax",
        "group:declarations"
      ],
      "weight": 1.32,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "variable",
      "title": "variable",
      "node_type": "concept",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "A mutable named value.",
        "Why": "Variables are usually the first declaration learners reach for.",
        "Example": "count := 0",
        "Pitfall": "Do not collapse variables and constants into the same mental slot.",
        "Signals": "Variable usage often appears near procedures and pointers."
      },
      "content_data": "Mutable storage in Odin.",
      "tags": [
        "group:declarations"
      ],
      "weight": 1.15,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "constant",
      "title": "constant",
      "node_type": "concept",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "An immutable named value.",
        "Why": "Constants separate stable compile-time intent from mutable runtime state.",
        "Example": "MAX_ITEMS :: 64",
        "Pitfall": "Overusing variables where a constant communicates intent more clearly.",
        "Signals": "Frequently connects conceptually to enum and declaration."
      },
      "content_data": "Immutable declaration in Odin.",
      "tags": [
        "group:declarations"
      ],
      "weight": 1.1,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "proc",
      "title": "proc",
      "node_type": "grammar",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Procedure declaration and callable behavior unit.",
        "Why": "Procedures are where declarations become active behavior.",
        "Example": "main :: proc() { }",
        "Pitfall": "Reading proc only as syntax instead of as the center of runtime patterns.",
        "Signals": "Strong bridge node into runtime and usage links."
      },
      "content_data": "Procedure declaration and execution unit.",
      "tags": [
        "group:declarations",
        "group:runtime"
      ],
      "weight": 1.28,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "struct",
      "title": "struct",
      "node_type": "concept",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Structured product type for named fields.",
        "Why": "Structs are central to data layout and procedure interaction.",
        "Example": "User :: struct { id: int, name: string }",
        "Pitfall": "Seeing struct only as storage instead of as a design boundary used by procedures and pointers.",
        "Signals": "Strongly related to pointer and proc."
      },
      "content_data": "Structured data type in Odin.",
      "tags": [
        "group:data"
      ],
      "weight": 1.2,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "enum",
      "title": "enum",
      "node_type": "concept",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Finite named set of values.",
        "Why": "Enums tighten state expression and work well with constants and switches.",
        "Example": "State :: enum { Idle, Busy, Failed }",
        "Pitfall": "Treating enum values like unstructured literals reduces clarity.",
        "Signals": "Often conceptually near constants."
      },
      "content_data": "Finite named states.",
      "tags": [
        "group:data",
        "group:declarations"
      ],
      "weight": 1.05,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "array",
      "title": "array",
      "node_type": "concept",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Fixed-length contiguous sequence.",
        "Why": "Arrays establish the data-layout baseline before slices.",
        "Example": "[4]int{1, 2, 3, 4}",
        "Pitfall": "Jumping to slices before understanding the fixed container underneath them.",
        "Signals": "Gradual links should reach slice from here."
      },
      "content_data": "Fixed-size collection.",
      "tags": [
        "group:data"
      ],
      "weight": 1.12,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "slice",
      "title": "slice",
      "node_type": "concept",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Dynamic view over sequential data.",
        "Why": "Slices are common in real code and link data layout to procedure usage.",
        "Example": "items[1:]",
        "Pitfall": "Using slices fluently without a clear model of the underlying data.",
        "Signals": "Connects to array conceptually and proc by usage."
      },
      "content_data": "Dynamic sequence view.",
      "tags": [
        "group:data",
        "group:runtime"
      ],
      "weight": 1.16,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "pointer",
      "title": "pointer",
      "node_type": "concept",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Reference to a memory location or value.",
        "Why": "Pointers are a key test for data-model and runtime edges in the graph.",
        "Example": "^User",
        "Pitfall": "Learning pointer syntax without understanding its relationship to structs and procedures.",
        "Signals": "Pairs with struct conceptually and with variable by usage."
      },
      "content_data": "Pointer semantics in Odin.",
      "tags": [
        "group:data",
        "group:runtime"
      ],
      "weight": 1.14,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "defer",
      "title": "defer",
      "node_type": "grammar",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Schedules a cleanup action for scope exit.",
        "Why": "This is a clear usage-pattern node rather than a pure syntax node.",
        "Example": "defer close(handle)",
        "Pitfall": "Treating defer as isolated syntax instead of a runtime management pattern.",
        "Signals": "Strong usage edge with proc."
      },
      "content_data": "Deferred cleanup pattern.",
      "tags": [
        "group:runtime"
      ],
      "weight": 1.08,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    },
    {
      "id": "context",
      "title": "context",
      "node_type": "concept",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Ambient execution state passed through runtime flow.",
        "Why": "Good test node for non-linear runtime links.",
        "Example": "A procedure may access contextual execution state instead of receiving every dependency explicitly.",
        "Pitfall": "Using context without a clear boundary around what belongs there.",
        "Signals": "Conceptual and usage links should both point toward proc."
      },
      "content_data": "Ambient execution context.",
      "tags": [
        "group:runtime"
      ],
      "weight": 1.06,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {}
    }
  ],
