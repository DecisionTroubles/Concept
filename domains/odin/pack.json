    {
      "id": "slice",
      "title": "slice",
      "node_type": "concept",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Dynamic view over sequential data.",
        "Why": "Slices are common in real code and link data layout to procedure usage.",
        "Example": "window := values[1:3]",
        "Pitfall": "Using slices fluently without a clear model of the underlying data.",
        "Signals": "Connects to array conceptually and proc by usage."
      },
      "content_data": "Dynamic sequence view.",
      "tags": [
        "group:data",
        "group:runtime"
      ],
      "weight": 1.16,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {},
      "sublayer_nodes": [
        {
          "id": "slice-view-owner",
          "title": "View, not owner",
          "node_type": "concept",
          "note_type_id": "odin-concept",
          "note_fields": {
            "Summary": "A slice is a dynamic view over sequence data, not the underlying storage itself.",
            "Why": "That distinction explains why array intuition still matters.",
            "Example": "Read a slice operation as selecting a window over existing sequential data.",
            "Pitfall": "Thinking the slice replaces the underlying layout model.",
            "Signals": "Parent = slice."
          },
          "content_data": "Sublayer note for slice.",
          "tags": [
            "group:data",
            "group:runtime"
          ],
          "weight": 0.8,
