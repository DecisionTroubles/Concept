      "title": "defer",
      "node_type": "grammar",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Schedules a cleanup action for scope exit.",
        "Why": "This is a clear usage-pattern node rather than a pure syntax node.",
        "Example": "file := open_file()\ndefer close_file(file)",
        "Pitfall": "Treating defer as isolated syntax instead of a runtime management pattern.",
        "Signals": "Strong usage edge with proc."
      },
      "content_data": "Deferred cleanup pattern.",
      "tags": [
        "group:runtime"
      ],
      "weight": 1.08,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {},
      "sublayer_nodes": [
        {
          "id": "defer-cleanup-timing",
          "title": "Cleanup timing",
          "node_type": "concept",
          "note_type_id": "odin-concept",
          "note_fields": {
            "Summary": "Defer is really about when cleanup is guaranteed to happen relative to scope exit.",
            "Why": "That makes it a runtime timing pattern, not just a keyword.",
            "Example": "Open resource now, schedule cleanup immediately, then continue with the body.",
            "Pitfall": "Reading defer as isolated syntax instead of execution ordering.",
            "Signals": "Parent = defer."
          },
          "content_data": "Sublayer note for defer.",
          "tags": [
            "group:runtime"
          ],
          "weight": 0.8,
          "layer_membership": [
            "core-map"
          ],
          "metadata": {}
        }
      ]
    },
    {
      "id": "context",
      "title": "context",
      "node_type": "concept",
      "note_type_id": "odin-concept",
      "note_fields": {
        "Summary": "Ambient execution state passed through runtime flow.",
        "Why": "Good test node for non-linear runtime links.",
        "Example": "render :: proc() {\n    theme := context.theme\n    _ = theme\n}",
        "Pitfall": "Using context without a clear boundary around what belongs there.",
        "Signals": "Conceptual and usage links should both point toward proc."
      },
      "content_data": "Ambient execution context.",
      "tags": [
        "group:runtime"
      ],
      "weight": 1.06,
      "layer_membership": [
        "core-map"
      ],
      "metadata": {},
      "sublayer_nodes": [
        {
          "id": "context-ambient-boundary",
          "title": "Ambient boundary",
          "node_type": "concept",
          "note_type_id": "odin-concept",
          "note_fields": {
            "Summary": "Context should carry only ambient execution state that belongs to the surrounding flow.",
            "Why": "Without that boundary, context becomes an unstructured dependency dump.",
            "Example": "Use context for execution-scoped state, not as a place to hide every parameter.",
            "Pitfall": "Treating context as a bag for anything inconvenient to pass explicitly.",
            "Signals": "Parent = context."
          },
          "content_data": "Sublayer note for context.",
          "tags": [
            "group:runtime"
          ],
          "weight": 0.8,
          "layer_membership": [
            "core-map"
          ],
          "metadata": {}
        }
      ]
    }
